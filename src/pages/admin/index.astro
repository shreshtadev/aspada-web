---
import AdminLayout from '@/layouts/AdminLayout.astro'
import { UsersFeatureOptions } from '@/types/pocketbase-types'
const { user } = Astro.locals
const features = user?.feature || []
const hasWebsite = features.includes(UsersFeatureOptions.website)
const hasCms = features.includes(UsersFeatureOptions.blog)
const hasCrm = features.includes(UsersFeatureOptions.crm)
const hasDms = features.includes(UsersFeatureOptions.dms)
---

<AdminLayout title="Admin Dashboard">
  <section class="space-y-8">
    <header>
      <h1 class="text-4xl font-extrabold text-aspada-navy tracking-tight">Admin Dashboard</h1>
      <p class="text-aspada-steel mt-2">Manage your business tools and content.</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
      {
        hasWebsite && (
          <>
            <a
              href="/admin/projects"
              class="group bg-white rounded-3xl p-8 border border-slate-200 shadow-lg hover:shadow-xl transition"
            >
              <h2 class="text-xl font-bold text-aspada-navy group-hover:text-aspada-gold">
                Projects
              </h2>
              <p class="mt-2 text-aspada-steel">Create, edit, and manage property projects.</p>
            </a>

            <a
              href="/admin/gallery"
              class="group bg-white rounded-3xl p-8 border border-slate-200 shadow-lg hover:shadow-xl transition"
            >
              <h2 class="text-xl font-bold text-aspada-navy group-hover:text-aspada-gold">
                Gallery
              </h2>
              <p class="mt-2 text-aspada-steel">Manage gallery images.</p>
            </a>

            <a
              href="/admin/testimonials"
              class="group bg-white rounded-3xl p-8 border border-slate-200 shadow-lg hover:shadow-xl transition"
            >
              <h2 class="text-xl font-bold text-aspada-navy group-hover:text-aspada-gold">
                Testimonials
              </h2>
              <p class="mt-2 text-aspada-steel">Manage customer testimonials and ratings.</p>
            </a>
            <a
              href="/admin/socials"
              class="group bg-white rounded-3xl p-8 border border-slate-200 shadow-lg hover:shadow-xl transition"
            >
              <h2 class="text-xl font-bold text-aspada-navy group-hover:text-aspada-gold">
                Social Details
              </h2>
              <p class="mt-2 text-aspada-steel">Manage social media links and handles.</p>
            </a>

            <a
              href="/admin/company"
              class="group bg-white rounded-3xl p-8 border border-slate-200 shadow-lg hover:shadow-xl transition"
            >
              <h2 class="text-xl font-bold text-aspada-navy group-hover:text-aspada-gold">
                Company Profile
              </h2>
              <p class="mt-2 text-aspada-steel">Update company contact info and address.</p>
            </a>
            <a
              href="/admin/stats"
              class="group bg-white rounded-3xl p-8 border border-slate-200 shadow-lg hover:shadow-xl transition"
            >
              <h2 class="text-xl font-bold text-aspada-navy group-hover:text-aspada-gold">Stats</h2>
              <p class="mt-2 text-aspada-steel">Manage property statistics and data.</p>
            </a>
          </>
        )
      }

      {
        hasCms && (
          <a
            href="/admin/blog"
            class="group bg-white rounded-3xl p-8 border border-slate-200 shadow-lg hover:shadow-xl transition"
          >
            <h2 class="text-xl font-bold text-aspada-navy group-hover:text-aspada-gold">Blog</h2>
            <p class="mt-2 text-aspada-steel">
              Manage blog posts and latest news for your clients.
            </p>
          </a>
        )
      }

      {
        hasCrm && (
          <a
            href="/crm"
            class="group bg-white rounded-3xl p-8 border border-slate-200 shadow-lg hover:shadow-xl transition"
          >
            <h2 class="text-xl font-bold text-aspada-navy group-hover:text-aspada-gold">CRM</h2>
            <p class="mt-2 text-aspada-steel">
              Manage leads, agents, and track pipeline activities.
            </p>
          </a>
        )
      }

      {
        hasDms && (
          <a
            href="/admin/dms"
            class="group bg-white rounded-3xl p-8 border border-slate-200 shadow-lg hover:shadow-xl transition"
          >
            <h2 class="text-xl font-bold text-aspada-navy group-hover:text-aspada-gold">DMS</h2>
            <p class="mt-2 text-aspada-steel">Manage documents and process workflows.</p>
          </a>
        )
      }
    </div>
  </section>
</AdminLayout>
