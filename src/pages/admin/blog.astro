---
import ContentManager from '../../components/admin/ContentManager.svelte'
import AdminLayout from '../../layouts/AdminLayout.astro'
---

<AdminLayout title="Admin Content Manager">
  <main class="min-h-screen p-8">
    <div class="max-w-6xl mx-auto">
      <header class="mb-10">
        <h1 class="text-4xl font-bold text-aspada-navy mb-2">Content Management</h1>
        <p class="text-slate-600">
          Manage your blog posts, categories, and tags from a single dashboard.
        </p>
      </header>

      <ContentManager client:idle />
    </div>
  </main>
</AdminLayout>
